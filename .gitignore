# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local

# ── Raw dataset files (large; download instructions in README) ────────────────
data/raw/*.csv
data/raw/*.zip
data/raw/*.txt
data/raw/*.parquet
!data/raw/.gitkeep

# ── Processed data (regenerated by notebooks) ────────────────────────────────
data/processed/*.csv
data/processed/*.parquet
data/processed/*.feather
data/processed/*.npz
data/processed/*.npy
data/processed/*.pkl
!data/processed/.gitkeep

# Poster cache (small, pre-fetched TMDB paths — commit to avoid cold-start API calls)
!data/cache/
!data/cache/poster_cache.json

# EDA figures (committed for README / docs)
!data/figures/

# ── SQLite user/interaction database ─────────────────────────────────────────
data/db.sqlite3

# ── Model artifacts (large; regenerate with: python scripts/train_and_export.py)
models/artifacts/*.npy
models/artifacts/*.npz
models/artifacts/*.pkl
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.csv
!models/.gitkeep
!models/artifacts/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/*.log
*.log

# ── Node / React ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/

# ── Testing / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Stale result dumps (reports/ JSON metrics are committed) ─────────────────
results/
reports/*.json
