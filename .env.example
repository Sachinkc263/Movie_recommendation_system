# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── Backend ───────────────────────────────────────────────────────────────────

# TMDB API key — required for poster image fetching.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Min interactions before SVD fold-in kicks in (default: 3)
COLD_START_THRESHOLD=3

# Set to "true" for verbose FastAPI output
DEBUG=false

# ── Frontend (Vite build-time) ────────────────────────────────────────────────

# Local development — call FastAPI directly:
VITE_API_URL=http://localhost:8000

# Docker Compose — nginx proxies /api/ to the backend (set in docker-compose.yml):
# VITE_API_URL=/api
